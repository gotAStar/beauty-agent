{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix app/frontend install",
  "buildCommand": "npm --prefix app/frontend run build",
  "outputDirectory": "app/frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://beauty-agent-cufm.onrender.com/api/$1"
    }
  ]
}
